#!/bin/sh
module=aesdchar
device=aesdchar
mode="666"

if grep -q '^staff:' /etc/group; then
    group="staff"
else
    group="wheel"
fi

case "$1" in
    start)
        echo "Loading ${module}"
        modprobe "${module}" || exit 1

        major=$(awk "\$2==\"$module\" {print \$1}" /proc/devices)
        if [ -z "$major" ]; then
            echo "Could not determine major number for ${module}"
            exit 1
        fi

        rm -f "/dev/${device}"
        mknod "/dev/${device}" c "$major" 0
        chgrp "$group" "/dev/${device}" || true
        chmod "$mode" "/dev/${device}"
        ;;
    stop)
        rm -f "/dev/${device}"
        rmmod "${module}" || exit 1
        ;;
    restart)
        $0 stop
        $0 start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0